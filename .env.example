# Copy to .env and fill in for local overrides. All are optional.

# Default account name used when --account is omitted
AUTO_IG_ACCOUNT=demo

# Directory for session files (storage_state JSON per account)
AUTO_IG_SESSIONS_DIR=./sessions

# Directory scanned by `auto-ig queue`
AUTO_IG_CONTENT_DIR=./content

# Queue SQLite DB path
AUTO_IG_QUEUE_DB=./sessions/queue.db

# Log level: DEBUG | INFO | WARNING | ERROR
AUTO_IG_LOG_LEVEL=INFO
